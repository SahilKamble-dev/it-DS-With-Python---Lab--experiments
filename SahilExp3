ction we will review them breifly.\n","\n","MATLAB-style Interface\n","Matplotlib was originally written as a Python alternative for MATLAB users, and much of its syntax reflects that fact. The MATLAB-style tools are contained in the pyplot (plt) interface. See the example inthe code cell below."],"metadata":{"id":"HkmqoLYoAnv7"}},{"cell_type":"code","source":["plt.figure()  # create a plot figure\n","\n","# create the first of two panels and set current axis\n","plt.subplot(2, 1, 1) # (rows, columns, panel number)\n","plt.plot(x, np.sin(x))\n","\n","# create the second panel and set current axis\n","plt.subplot(2, 1, 2)\n","plt.plot(x, np.cos(x));"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":440},"id":"ql0b21qQAoqB","executionInfo":{"status":"ok","timestamp":1771338641528,"user_tz":-330,"elapsed":309,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"440a1458-5448-485e-96ea-5bd431c81b45"},"execution_count":7,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["#First create a grid of plots\n","# ax will be an array of two Axes objects\n","fig, ax = plt.subplots(2)\n","\n","# Call plot() method on the appropriate object\n","ax[0].plot(x, np.sin(x))\n","ax[1].plot(x, np.cos(x))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":457},"id":"UUIgsdlVAu3a","executionInfo":{"status":"ok","timestamp":1771338661477,"user_tz":-330,"elapsed":19,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"8c6b846f-90cf-4081-9cba-d8dd9a748602"},"execution_count":8,"outputs":[{"output_type":"execute_result","data":{"text/plain":["[<matplotlib.lines.Line2D at 0x797dcfe4f230>]"]},"metadata":{},"execution_count":8},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# creating objects of figure and axes.\n","fig = plt.figure()\n","ax = plt.axes()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":440},"id":"U-iuATBKAye7","executionInfo":{"status":"ok","timestamp":1771338688548,"user_tz":-330,"elapsed":89,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"1521fcbd-590f-4028-ddeb-cfc1b4c0c91d"},"execution_count":10,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# we will plot sine curve using ax.plot function\n","fig = plt.figure()\n","ax = plt.axes()\n","x = np.linspace(0, 10, 1000)\n","ax.plot(x, np.sin(x));"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":440},"id":"KC0LIvL_A5Id","executionInfo":{"status":"ok","timestamp":1771338702704,"user_tz":-330,"elapsed":149,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"a48a9d2c-b1cf-4c33-f6f4-3d96afb2c276"},"execution_count":11,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["\n","plt.plot(x, np.sin(x))   #shown in blue\n","plt.plot(x, np.sin(2*x)) #Shown in green\n","plt.plot(x,(x**(1/2))/2) #Shown in red\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":457},"id":"tZrKT3FQA8mF","executionInfo":{"status":"ok","timestamp":1771338718841,"user_tz":-330,"elapsed":188,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"8fc07456-4c48-4c41-8474-b3730823ba3a"},"execution_count":12,"outputs":[{"output_type":"execute_result","data":{"text/plain":["[<matplotlib.lines.Line2D at 0x797dda16b710>]"]},"metadata":{},"execution_count":12},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["plt.plot(x, x + 0, linestyle='solid')\n","plt.plot(x, x + 1, linestyle='dashed')\n","plt.plot(x, x + 2, linestyle='dashdot')\n","plt.plot(x, x + 3, linestyle='dotted');\n","\n","# For short, you can use the following codes:\n","plt.plot(x, x + 4, linestyle='-')  # solid\n","plt.plot(x, x + 5, linestyle='--') # dashed\n","plt.plot(x, x + 6, linestyle='-.') # dashdot\n","plt.plot(x, x + 7, linestyle=':');  # dotted\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":440},"id":"opye6C_aBCJj","executionInfo":{"status":"ok","timestamp":1771338748014,"user_tz":-330,"elapsed":3271,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"6d2543c7-7b4a-40fc-f451-ad133ad54e4f"},"execution_count":13,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["plt.plot(x, np.sin(x))\n","\n","plt.xlim(-1, 11)\n","plt.ylim(-1.5, 1.5);"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":440},"id":"eoPFbF93BGMr","executionInfo":{"status":"ok","timestamp":1771338763088,"user_tz":-330,"elapsed":10,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"d4bf9725-1468-44fc-c258-445527f23f79"},"execution_count":14,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Reverse the Axis Limit\n","plt.plot(x, np.sin(x))\n","\n","plt.xlim(10, 0)\n","plt.ylim(1.2, -1.2);"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":434},"id":"6PPke-h2BLHk","executionInfo":{"status":"ok","timestamp":1771338778089,"user_tz":-330,"elapsed":9,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"7415cac5-e833-45b5-d64e-cf82192025d7"},"execution_count":15,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["plt.plot(x, np.sin(x))\n","plt.title(\"A Sine Curve\")\n","plt.xlabel(\"x\")\n","plt.ylabel(\"sin(x)\");\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":470},"id":"_YcLLBIkBPUz","executionInfo":{"status":"ok","timestamp":1771338803138,"user_tz":-330,"elapsed":12,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"ea4acd8e-a1a2-43bc-b634-7431ee4e8e5b"},"execution_count":16,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["\n","# Consider this code for scatter plot\n","\n","rng = np.random.RandomState(0)\n","x = rng.randn(100)\n","y = rng.randn(100)\n","colors = rng.rand(100)\n","sizes = 1000 * rng.rand(100)\n","\n","plt.scatter(x, y, c=colors, s=sizes, alpha=0.3,\n","            cmap='viridis')\n","plt.colorbar();  # show color scale"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":440},"id":"XwNrzo-ZBUgC","executionInfo":{"status":"ok","timestamp":1771338816760,"user_tz":-330,"elapsed":333,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"a96537d9-294a-410d-f0e0-e724f1328de3"},"execution_count":17,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["**1 :- List any 2 python APIs that are used for Plotting Graphs.**"],"metadata":{"id":"93qAt0ULBayZ"}},{"cell_type":"markdown","source":["ans :-  1:- Matplotlib\n","\n","Most popular plotting library in Python.\n","\n","Used to create line graphs, bar charts, pie charts, histograms, scatter plots, etc.\n","\n","Example use: import matplotlib.pyplot as plt\n","import matplotlib.pyplot as plt\n","\n","x = [1, 2, 3, 4]\n","y = [10, 20, 25, 30]\n","\n","plt.plot(x, y)\n","plt.title(\"Simple Line Graph\")\n","plt.show()\n","2 :- Seaborn\n","\n","Built on top of Matplotlib.\n","\n","Used for statistical data visualization.\n","\n","Provides attractive and informative graphics with less code.\n","\n","Example use: import seaborn as sns\n","import seaborn as sns\n","import matplotlib.pyplot as plt\n","\n","x = [1, 2, 3, 4]\n","y = [10, 20, 25, 30]\n","\n","sns.lineplot(x=x, y=y)\n","plt.title(\"Seaborn Line Graph\")\n","plt.show()\n"],"metadata":{"id":"EI9ZE0lVBtCF"}},{"cell_type":"markdown","source":["** 2:- Name 2 important machnisms used for accesssing Matplotlib API.**"],"metadata":{"id":"HiT3CcRvB-kf"}},{"cell_type":"markdown","source":["Pyplot Interface (State-Based Interface)\n","🔹 What it is:\n","\n","The Pyplot interface is a simple and commonly used way of plotting graphs in Matplotlib.\n","It is state-based, meaning it automatically manages the current figure and axes for you.\n","\n","It is similar to MATLAB plotting style.\n","\n","🔹 How it works:\n","\n","Uses matplotlib.pyplot\n","\n","Automatically creates figure and axes\n","\n","Good for small programs and beginners\n","\n","Less control compared to Object-Oriented approach\n","\n","🔹 Example:\n","import matplotlib.pyplot as plt\n","\n","x = [1, 2, 3, 4]\n","y = [10, 20, 25, 30]\n","\n","plt.plot(x, y)\n","plt.title(\"Line Graph\")\n","plt.xlabel(\"X-axis\")\n","plt.ylabel(\"Y-axis\")\n","plt.show()\n","Advantages:\n","\n"," Easy to learn\n"," Requires less code\n"," Best for quick plotting\n","\n","🔹 Disadvantages:\n","\n"," Less flexible for complex plots\n"," Not ideal for large applications\n"," Object-Oriented (OO) Interface\n","🔹 What it is:\n","\n","The Object-Oriented interface gives full control over figures and axes.\n","Instead of relying on automatic state handling, you create and manage plot objects manually.\n","\n","🔹 How it works:\n","\n","Uses Figure and Axes objects\n","\n","More powerful and flexible\n","\n","Best for complex or professional applications\n","\n","🔹 Example:\n","import matplotlib.pyplot as plt\n","\n","x = [1, 2, 3, 4]\n","y = [10, 20, 25, 30]\n","\n","fig, ax = plt.subplots()   # create figure and axes\n","ax.plot(x, y)\n","ax.set_title(\"Line Graph\")\n","ax.set_xlabel(\"X-axis\")\n","ax.set_ylabel(\"Y-axis\")\n","\n","plt.show()\n","Advantages:\n","\n"," More control\n"," Better for multiple plots\n"," Recommended for large projects\n","\n","🔹 Disadvantages:\n","\n"," Slightly more code\n"," Slightly harder for beginners"],"metadata":{"id":"IeIpnowVCPrE"}},{"cell_type":"markdown","source":["**3:- Create a collection of 100 random normal numbers with parameter mean 30, sd 4 store it in object summer_temp**"],"metadata":{"id":"QRoPqP_XCh6y"}},{"cell_type":"markdown","source":["ans :- You can create 100 random normal numbers using NumPy like this:\n","import numpy as np\n","\n","# Create 100 random normal numbers\n","summer_temp = np.random.normal(loc=30, scale=4, size=100)\n","\n","print(summer_temp)\n","Explanation:\n","\n","loc=30 → mean = 30\n","\n","scale=4 → standard deviation = 4\n","\n","size=100 → total 100 random values\n","\n","Stored in object summer_temp"],"metadata":{"id":"-fRMFxA_CnZU"}},{"cell_type":"markdown","source":["**4:- Sort above set and store in objrct sorted_summer_temp**"],"metadata":{"id":"oumtKNBFDGLV"}},{"cell_type":"markdown","source":["import numpy as np\n","\n","# Create 100 random normal numbers\n","summer_temp = np.random.normal(loc=30, scale=4, size=100)\n","\n","# Sort the array\n","sorted_summer_temp = np.sort(summer_temp)\n","\n","print(sorted_summer_temp)\n","Explanation:\n","\n","np.sort() → sorts the array in ascending order\n","\n","Sorted values are stored in sorted_summer_temp"],"metadata":{"id":"5I8I1FPbDXy5"}},{"cell_type":"markdown","source":["**5 :- Store average of 25 consecutive elements from sorted_summer_temp into object x and plot it as a line plot. What kind of information do u get about the data?**"],"metadata":{"id":"u_Jo-CPyDa7f"}},{"cell_type":"code","source":["import numpy as np\n","import matplotlib.pyplot as plt\n","\n","# Step 1: Generate data\n","summer_temp = np.random.normal(loc=30, scale=4, size=100)\n","\n","# Step 2: Sort data\n","sorted_summer_temp = np.sort(summer_temp)\n","\n","# Step 3: Compute average of every 25 consecutive elements\n","x = []\n","\n","for i in range(0, 100, 25):\n","    avg = np.mean(sorted_summer_temp[i:i+25])\n","    x.append(avg)\n","\n","x = np.array(x)\n","\n","# Step 4: Plot line graph\n","plt.plot(x)\n","plt.title(\"Average of 25 Consecutive Sorted Values\")\n","plt.xlabel(\"Group Number\")\n","plt.ylabel(\"Average Temperature\")\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":470},"id":"6jTx7B-lDnPD","executionInfo":{"status":"ok","timestamp":1771339426604,"user_tz":-330,"elapsed":166,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"1dde5963-f680-4cc1-eaeb-1f4b3572cce8"},"execution_count":18,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["**6:- Repeat above step for summer_temp, store summary in object y and this time use scatter plot to plot values. What kind of information do u get about the data?**"],"metadata":{"id":"WRTdqj0TDw9v"}},{"cell_type":"code","source":["import numpy as np\n","import matplotlib.pyplot as plt\n","\n","# Step 1: Generate data\n","summer_temp = np.random.normal(loc=30, scale=4, size=100)\n","\n","# Step 2: Compute average of every 25 consecutive elements (without sorting)\n","y = []\n","\n","for i in range(0, 100, 25):\n","    avg = np.mean(summer_temp[i:i+25])\n","    y.append(avg)\n","\n","y = np.array(y)\n","\n","# Step 3: Scatter Plot\n","plt.scatter(range(1, 5), y)\n","plt.title(\"Average of 25 Consecutive Values (Unsorted Data)\")\n","plt.xlabel(\"Group Number\")\n","plt.ylabel(\"Average Temperature\")\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":470},"id":"y0K-YPAWD2AW","executionInfo":{"status":"ok","timestamp":1771339480078,"user_tz":-330,"elapsed":186,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"9a579f21-211c-4971-cc29-33004e54b96b"},"execution_count":19,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["**7 :- plot summer_temp and y together in same line plot.**"],"metadata":{"id":"qyNIbElwD8Qq"}},{"cell_type":"code","source":["import numpy as np\n","import matplotlib.pyplot as plt\n","\n","# Generate data\n","summer_temp = np.random.normal(loc=30, scale=4, size=100)\n","\n","# Compute average of every 25 consecutive elements\n","y = []\n","for i in range(0, 100, 25):\n","    avg = np.mean(summer_temp[i:i+25])\n","    y.append(avg)\n","\n","y = np.array(y)\n","\n","# Plot both in same graph\n","plt.plot(summer_temp, label=\"Summer Temp (Raw Data)\")\n","plt.plot(range(0, 100, 25), y, marker='o', label=\"Average of 25 Values\")\n","\n","plt.title(\"Summer Temp and Group Averages\")\n","plt.xlabel(\"Index\")\n","plt.ylabel(\"Temperature\")\n","plt.legend()\n","plt.show()\n"],"metadata":{"id":"pXGhIjjmEGJ7","executionInfo":{"status":"ok","timestamp":1771339543722,"user_tz":-330,"elapsed":559,"user":{"displayName":"kamble sahil","userId":"09120746576668669659"}},"outputId":"596a5840-710d-42e4-d87a-35b3466c05ac","colab":{"base_uri":"https://localhost:8080/","height":470}},"execution_count":20,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]}]}